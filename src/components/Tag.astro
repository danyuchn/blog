---
import { withBase } from "@/utils/withBase";

type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
};

const { tag, tagName, size = "lg" } = Astro.props;
---

<li>
  <a
    href={withBase(`/tags/${tag}/`)}
    transition:name={tag}
    class:list={[
      "inline-block border border-foreground/40 tracking-wide uppercase",
      "hover:border-accent hover:text-accent focus-visible:text-accent",
      { "px-2 py-0.5 text-xs": size === "sm" },
      { "px-2.5 py-1 text-sm": size === "lg" },
    ]}
  >
    {tagName}
  </a>
</li>
