---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import { getLangFromPost } from "@/utils/i18n";
import { withBase } from "@/utils/withBase";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const post = Astro.props;
const { variant: Heading = "h2", id, data, filePath } = post;
const lang = getLangFromPost(post);

const { title, description, tags, featured, ...props } = data;
const isFeatured = featured ?? false;
---

<li
  class:list={[
    "grid grid-cols-1 gap-x-8 border-b border-border sm:grid-cols-[7.5rem_1fr]",
    { "py-8": isFeatured },
    { "py-6": !isFeatured },
  ]}
  data-lang={lang}
>
  <div
    class="mb-2 flex flex-wrap items-baseline gap-x-3 gap-y-1 text-sm text-foreground/60 sm:mb-0 sm:flex-col sm:items-start sm:gap-y-2 sm:pt-1"
  >
    <Datetime {...props} />
    {
      tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-x-2 gap-y-1">
          {tags.map(tag => (
            <a
              href={withBase(`/tags/${slugifyStr(tag)}/`)}
              class="text-xs tracking-wide uppercase hover:text-accent"
            >
              {tag}
            </a>
          ))}
        </div>
      )
    }
  </div>
  <div>
    <Heading
      style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
      class:list={[
        "font-display leading-snug font-bold text-foreground",
        { "text-2xl sm:text-3xl": isFeatured },
        { "text-lg sm:text-xl": !isFeatured },
      ]}
    >
      <a
        href={getPath(id, filePath)}
        class="transition-colors duration-150 hover:text-accent focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent"
      >
        {title}
      </a>
    </Heading>
    {
      description && (
        <p class="mt-2 text-sm leading-relaxed text-foreground/70">
          {description}
        </p>
      )
    }
  </div>
</li>
