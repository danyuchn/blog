---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import { getLangFromPost } from "@/utils/i18n";
import { withBase } from "@/utils/withBase";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const post = Astro.props;
const { variant: Heading = "h2", id, data, filePath } = post;
const lang = getLangFromPost(post);

const { title, description, tags, featured, ...props } = data;
const isFeatured = featured ?? false;
---

<li
  class:list={[
    "group border-b border-border/50 last:border-0",
    { "py-8": isFeatured },
    { "py-5": !isFeatured },
  ]}
  data-lang={lang}
>
  <a
    href={getPath(id, filePath)}
    class="block focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent"
  >
    <div class:list={["flex items-start justify-between gap-4"]}>
      <Heading
        style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
        class:list={[
          "font-display font-semibold leading-snug text-foreground",
          "transition-colors duration-150 group-hover:text-accent",
          { "text-xl sm:text-2xl": isFeatured },
          { "text-base sm:text-lg": !isFeatured },
        ]}
      >
        {title}
      </Heading>
      <span class="mt-1 shrink-0 opacity-0 transition-opacity duration-150 group-hover:opacity-100" aria-hidden="true">→</span>
    </div>
    <div class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-foreground/55">
      <Datetime {...props} />
      {
        tags && tags.length > 0 &&
          tags.map(tag => (
            <a
              href={withBase(`/tags/${slugifyStr(tag)}/`)}
              class="hover:text-accent transition-colors"
              onclick="event.stopPropagation()"
            >
              {tag}
            </a>
          ))
      }
    </div>
    {
      isFeatured && description && (
        <p class="mt-3 text-base leading-relaxed text-foreground/70">{description}</p>
      )
    }
  </a>
</li>
