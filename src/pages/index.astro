---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";
import { withBase } from "@/utils/withBase";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class="border-b border-border/50 pt-16 pb-12">
      <h1
        class="font-display text-4xl font-bold leading-tight tracking-tight text-foreground sm:text-5xl"
        data-lang="zh"
      >
        嗨，我是 Dustin。
      </h1>
      <h1
        class="font-display text-4xl font-bold italic leading-tight tracking-tight text-foreground sm:text-5xl"
        data-lang="en"
      >
        Hi, I'm Dustin.
      </h1>

      <div class="mt-6 max-w-prose">
        <p class="text-base leading-relaxed text-foreground/70" data-lang="zh">
          教了 12 年 GMAT，現在人在曼谷，用 AI 做教育產品。這裡寫的是一個沒有工程背景的人，怎麼靠 Claude Code 和 Gemini 把東西做出來的過程，還有途中踩過的坑。
        </p>
        <p class="mt-2 text-base leading-relaxed text-foreground/70" data-lang="en">
          12 years teaching GMAT. Now based in Bangkok, building education products with AI. This blog is about how someone with zero engineering background actually ships things — and all the pitfalls along the way.
        </p>
      </div>

      <div class="mt-6 flex items-center gap-4">
        {
          SOCIALS.length > 0 && <Socials />
        }
        <a
          target="_blank"
          href={withBase("/rss.xml")}
          class="text-foreground/40 hover:text-accent transition-colors"
          aria-label="RSS Feed"
          title="RSS Feed"
        >
          <IconRss width={16} height={16} class="stroke-current stroke-2" />
          <span class="sr-only">RSS Feed</span>
        </a>
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-10 pb-4",
            { "border-b border-border/50": recentPosts.length > 0 },
          ]}
        >
          <p class="mb-2 font-display text-sm font-semibold uppercase tracking-widest text-accent">
            精選
          </p>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h2" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-10 pb-4">
          <p class="mb-2 font-display text-sm font-semibold uppercase tracking-widest text-foreground/50">
            最近在寫
          </p>
          <ul>
            {recentPosts.map(data => <Card variant="h3" {...data} />)}
          </ul>
        </section>
      )
    }

    <div class="py-8">
      <LinkButton
        href={withBase("/posts/")}
        class="text-sm text-foreground/50 hover:text-accent transition-colors"
      >
        所有文章 →
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", window.location.pathname);
    }
  });
</script>
