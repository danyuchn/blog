---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import GridCard from "@/components/GridCard.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { filterByLang } from "@/utils/i18n";
import IconRss from "@/assets/icons/IconRss.svg";
import { SOCIALS } from "@/constants";
import { withBase } from "@/utils/withBase";

const RECENT_COUNT = 6;

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
// 雙語各取最新 N 篇再合併渲染（LangSwitcher 以 display:none 過濾另一語言）。
// 不可在 zh/en 混合陣列上 slice——每語言可見篇數會不可控。
const recentPosts = (["zh", "en"] as const).flatMap(lang =>
  filterByLang(sortedPosts, lang)
    .filter(({ data }) => !data.featured)
    .slice(0, RECENT_COUNT)
);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class="border-b-2 border-foreground pt-16 pb-12">
      <h1
        class="font-display text-4xl leading-tight font-black tracking-tight text-foreground sm:text-6xl"
        data-lang="zh"
      >
        嗨，我是 Dustin。
      </h1>
      <h1
        class="font-display text-4xl leading-tight font-black tracking-tight text-foreground sm:text-6xl"
        data-lang="en"
      >
        Hi, I'm Dustin.
      </h1>

      <div class="mt-6 max-w-prose">
        <p class="text-base leading-relaxed text-foreground/70" data-lang="zh">
          教了 12 年 GMAT，現在人在曼谷，用 AI
          做教育產品。這裡寫的是一個沒有工程背景的人，怎麼靠 Claude Code 和
          Gemini 把東西做出來的過程，還有途中踩過的坑。
        </p>
        <p
          class="mt-2 text-base leading-relaxed text-foreground/70"
          data-lang="en"
        >
          12 years teaching GMAT. Now based in Bangkok, building education
          products with AI. This blog is about how someone with zero engineering
          background actually ships things — and all the pitfalls along the way.
        </p>
      </div>

      <div class="mt-6 flex items-center gap-4">
        {SOCIALS.length > 0 && <Socials />}
        <a
          target="_blank"
          href={withBase("/rss.xml")}
          class="text-foreground/40 transition-colors hover:text-accent"
          aria-label="RSS Feed"
          title="RSS Feed"
        >
          <IconRss width={16} height={16} class="stroke-current stroke-2" />
          <span class="sr-only">RSS Feed</span>
        </a>
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-8 pb-8",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <p class="mb-6 text-sm font-semibold tracking-widest text-accent uppercase">
            精選
          </p>
          <ul class="grid grid-cols-1 gap-x-8 gap-y-8 sm:grid-cols-2 lg:grid-cols-3">
            {featuredPosts.map(post => (
              <GridCard {...post} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-10 pb-4">
          <p class="mb-2 text-sm font-semibold tracking-widest text-foreground/50 uppercase">
            最近在寫
          </p>
          <ul>
            {recentPosts.map(post => (
              <Card variant="h3" {...post} />
            ))}
          </ul>
        </section>
      )
    }

    <div class="py-8">
      <LinkButton
        href={withBase("/posts/")}
        class="text-sm text-foreground/50 transition-colors hover:text-accent"
      >
        所有文章 →
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", window.location.pathname);
    }
  });
</script>
